{
  "version": 2,
  "routes": [
    {
      "src": "/data/(.*)",
      "dest": "/data/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/scripts/(.*)",
      "dest": "/scripts/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
